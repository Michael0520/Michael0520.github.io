"api/tags/JavaScript.json"}],"author":{"name":"Michael","slug":"blog-author","avatar":"https://img-blog.csdnimg.cn/20210313122054101.png","link":"/","description":"happy coding!","socials":{"github":"https://github.com/Michael0520","twitter":"","stackoverflow":"","wechat":"","qq":"","weibo":"","zhihu":"","csdn":"","juejin":"","customs":{}}},"feature":true},"next_post":{"title":"Final-Project 需求分析","uid":"dda1dc6fec4e01e6b9f71bae121cafc2","slug":"Final-Project-需求分析","date":"2021-09-27T16:00:00.000Z","updated":"2022-06-13T13:59:22.000Z","comments":true,"path":"api/articles/Final-Project-需求分析.json","keywords":null,"cover":[],"text":"進度 Update5&#x2F;17 週一 補看昨天直播影片 期末專題選題目 租房網站 開始進行需求分析 首頁輪播式照片 (swipper 套件) 因為無會員登入功能，所以將預訂需求改為表單填寫，因此要做”表單驗證”功能 搜尋功能 城市搜尋(ex:台北市) 房型搜尋(ex:四人房...","link":"","photos":[],"count_time":{"symbolsCount":"1.6k","symbolsTime":"1 mins."},"categories":[{"name":"JavaScript","slug":"JavaScript","count":42,"path":"api/categories/JavaScript.json"},{"name":"作品集","slug":"JavaScript/作品集","count":18,"path":"api/categories/JavaScript/作品集.json"}],"tags":[{"name":"JavaScript","slug":"JavaScript","count":36,"path":"api/tags/JavaScript.json"},{"name":"作品集","slug":"作品集","count":19,"path":"api/tags/作品集.json"}],"author":{"name":"Michael","slug":"blog-author","avatar":"https://img-blog.csdnimg.cn/20210313122054101.png","link":"/","description":"happy coding!","socials":{"github":"https://github.com/Michael0520","twitter":"","stackoverflow":"","wechat":"","qq":"","weibo":"","zhihu":"","csdn":"","juejin":"","customs":{}}}}}